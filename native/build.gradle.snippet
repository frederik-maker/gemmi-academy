// Paste these into android/app/build.gradle inside the `dependencies { ... }`
// block. The install script splices them in automatically if it sees the
// marker comment below.
// MARKER: gemmi-tutor-deps

dependencies {
    // MediaPipe LLM Inference API for loading the Gemma 4 .task file.
    // We use 'tasks-genai' rather than 'litert-lm' because the pre-converted
    // task bundles on Hugging Face are MediaPipe-compatible.
    implementation "com.google.mediapipe:tasks-genai:0.10.+"
    implementation "org.jetbrains.kotlinx:kotlinx-coroutines-android:1.7.+"
}

android {
    // The .task file is downloaded to filesDir at runtime, never bundled in
    // the APK. The aaptOptions block is a safety net in case anyone copies a
    // .task into assets/ for local testing.
    aaptOptions {
        noCompress "task"
    }
}
