{
  "appId": "co.bussler.gemmi",
  "appName": "Gemmi Academy",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#1186f5",
      "showSpinner": false,
      "androidSplashResourceName": "splash"
    }
  }
}
